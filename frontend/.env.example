# ─────────────────────────────────────────────────────────────────────
#  Frontend environment variables
#  Copy this to frontend/.env and fill in your values.
#  REACT_APP_ prefix is REQUIRED for Create React App to expose vars.
# ─────────────────────────────────────────────────────────────────────

# Deployed PaperRegistry contract address (after running deploy.js)
REACT_APP_CONTRACT_ADDRESS=0xYourContractAddressHere

# Pinata API credentials (used directly from the browser)
# Leave blank to use manual CID entry mode instead.
REACT_APP_PINATA_API_KEY=your_pinata_api_key
REACT_APP_PINATA_SECRET=your_pinata_secret_key
