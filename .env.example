# ─────────────────────────────────────────────────────────────────────────────
#  Proof of Precedence — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit your real .env to version control!
# ─────────────────────────────────────────────────────────────────────────────

# Wallet private key (without 0x prefix is also fine with ethers v6)
PRIVATE_KEY=your_wallet_private_key_here

# RPC endpoint — use a local Hardhat node or a Polygon Mumbai URL
# Local:   http://127.0.0.1:8545
# Mumbai:  https://rpc-mumbai.maticvigil.com  OR  an Alchemy/Infura endpoint
RPC_URL=http://127.0.0.1:8545

# Pinata IPFS credentials — get them at https://app.pinata.cloud/keys
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here

# Deployed contract address (filled in after running deploy.js)
CONTRACT_ADDRESS=

# Optional: Polygonscan API key for contract verification
POLYGONSCAN_API_KEY=
